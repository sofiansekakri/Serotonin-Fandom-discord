[CMD] /notes UserID: 1125277035078615051, UserTag: dahlir, GuildID: 1405247681634500673, Options: [{"name":"user","type":6,"value":"191550896935665664","user":{"id":"191550896935665664","bot":false,"system":false,"flags":640,"username":"___raina","globalName":"RainA","discriminator":"0","avatar":"39bacce615123c293bdd62327440e789","avatarDecoration":null,"avatarDecorationData":null,"collectibles":null,"primaryGuild":null,"createdTimestamp":1465739692673,"defaultAvatarURL":"https://cdn.discordapp.com/embed/avatars/5.png","tag":"___raina","avatarURL":"https://cdn.discordapp.com/avatars/191550896935665664/39bacce615123c293bdd62327440e789.webp","displayAvatarURL":"https://cdn.discordapp.com/avatars/191550896935665664/39bacce615123c293bdd62327440e789.webp","guildTagBadgeURL":null},"member":{"guildId":"1405247681634500673","premiumSinceTimestamp":null,"nickname":"obese bear with hairy toes","pending":false,"communicationDisabledUntilTimestamp":null,"userId":"191550896935665664","avatar":null,"banner":null,"joinedTimestamp":1774808598223,"flags":0,"avatarDecorationData":null,"displayName":"obese bear with hairy toes","roles":["1405247681634500673"],"avatarURL":null,"bannerURL":null,"displayAvatarURL":"https://cdn.discordapp.com/avatars/191550896935665664/39bacce615123c293bdd62327440e789.webp","avatarDecorationURL":null}},{"name":"type","type":3,"value":"edit"},{"name":"content","type":3,"value":"Ich habe in ein Flugzeugtriebwerk gekackt und jetzt drohen mir drei Jahre in einer Hochsicherheitsstrafanstalt.  Hallo, ich bin Jackie Chan, Shrek, und das ist meine Geschichte.  Eines Tages war ich am Flughafen.  Ich wollte die Flugzeuge beim Starten beobachten.  Also ging ich auf die Startbahn.  Und plötzlich bekam ich Bauchschmerzen.  Ich hatte keine Wahl.  Also musste ich in eines der Triebwerke kacken.  Als das Flugzeug beschleunigte, verteilte sich der ganze Kot über die Startbahn.  Die Leute fingen an, ihn in unglaublicher Geschwindigkeit aufzulecken.  Aber am Ende hat mich die Polizei erwischt, und mir drohen bis zu drei Jahre in einer Hochsicherheitsstrafanstalt."}]
